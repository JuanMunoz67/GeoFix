<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/card_background"
            app:titleTextColor="@color/white"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header del ticket -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/card_background">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/tvTicketTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pendiente"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            app:chipStrokeWidth="0dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Fila de detalles -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_columnWeight="1" android:orientation="vertical" android:layout_margin="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="TIPO" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvType" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="14sp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_columnWeight="1" android:orientation="vertical" android:layout_margin="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="PRIORIDAD" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvPriority" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_columnWeight="1" android:orientation="vertical" android:layout_margin="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="UBICACIÓN" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvLocation" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="14sp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_columnWeight="1" android:orientation="vertical" android:layout_margin="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="REPORTADO POR" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvUserEmail" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="12sp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:layout_columnSpan="2" android:orientation="vertical" android:layout_margin="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="FECHA" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvCreatedAt" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:textColor="@color/white" android:textSize="14sp"/>
                        </LinearLayout>
                    </GridLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Imágenes -->
            <LinearLayout
                android:id="@+id/sectionImages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Evidencias"
                        android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewPhotos"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ver todas" android:textColor="@color/primary_blue"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvImages"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"/>
            </LinearLayout>

            <!-- Comentarios -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Comentarios y Seguimiento"
                android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvComments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="12dp"/>

            <!-- Input de comentario -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:hint="Agregar comentario..."
                    app:hintTextColor="@color/primary_blue"
                    app:boxStrokeColor="@color/primary_blue">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etComment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnSendComment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_send"
                    app:backgroundTint="@color/primary_blue"
                    app:tint="@color/white"
                    app:fabSize="mini"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
